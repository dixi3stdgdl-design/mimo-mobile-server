# MiMo Mobile Server Configuration
# Copy this file to .env and customize

# Path to MiMo CLI binary
MIMO_CMD=~/.mimocode/bin/mimo

# Authentication PIN (must match app settings)
MIMO_AUTH_PIN=MIMO2026

# Workspace root directory
MIMO_WORKSPACE=~

# Server display name (shown in app auto-discovery)
MIMO_SERVER_NAME=MiMo-PC

# Android SDK path (for ADB device management)
# ANDROID_HOME=/path/to/android/sdk
