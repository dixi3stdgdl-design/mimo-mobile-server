# ─── Server Configuration ─────────────────────────────────────────────
MIMO_WS_PORT=8765
MIMO_HTTP_PORT=8080
MIMO_WORKSPACE=~
MIMO_CMD=~/.mimocode/bin/mimo
MIMO_SERVER_NAME=$(hostname)
MIMO_WORKERS=1

# ─── Authentication ───────────────────────────────────────────────────
# Legacy PIN (backward compatible)
MIMO_AUTH_PIN=MIMO2026

# JWT Secret (REQUIRED for production — generate with: python -c 'import secrets; print(secrets.token_hex(32))')
MIMO_JWT_SECRET=
MIMO_JWT_EXPIRY=86400

# API Keys (format: key1:user1,key2:user2)
MIMO_API_KEYS=

# ─── TLS / HTTPS ──────────────────────────────────────────────────────
# Enable TLS for WebSocket and HTTP
MIMO_TLS_ENABLED=false
MIMO_TLS_CERT_DIR=./certs

# ─── Cloudflare Tunnel ────────────────────────────────────────────────
# Enable Cloudflare Tunnel for external access
MIMO_CLOUDFLARE_TUNNEL=false
MIMO_EXTERNAL_HOST=mimo.yourdomain.com
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# ─── CORS ─────────────────────────────────────────────────────────────
# Comma-separated allowed origins (use * for development)
MIMO_CORS_ORIGINS=*

# ─── Analytics ────────────────────────────────────────────────────────
# Enable persistent analytics (SQLite)
MIMO_ANALYTICS_ENABLED=true
MIMO_ANALYTICS_DB=~/.mimo/analytics.db

# ─── Redis (for scaling) ─────────────────────────────────────────────
REDIS_URL=

# ─── Database (for production) ────────────────────────────────────────
POSTGRES_PASSWORD=mimo_secret

# ─── Monitoring ───────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
